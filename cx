#!/usr/bin/env bash
# cx — thin dispatcher to the installed claudex tier(s)
set -euo pipefail

usage() {
  cat <<EOF
Usage: cx [lite|full] [args...]
       cx --help

Dispatches to the Claude session picker:
  - Subcommand 'lite' or 'full' forces that tier.
  - Otherwise, 'claudex' (full) is used if installed; else 'claudex-lite'.

Note: as of v0.1.0, this repo only ships the 'lite' tier ('claudex-lite').
If you have installed 'claudex' separately, the default still prefers it;
use the 'lite' subcommand to force 'claudex-lite'.

All other arguments pass through to the chosen tier.
  cx --all        default tier, scope broadened to all sessions
  cx lite --all   lite tier explicitly, --all passed through
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    ;;
  lite)
    shift
    if ! command -v claudex-lite >/dev/null 2>&1; then
      echo "cx: 'claudex-lite' not on PATH." >&2
      exit 1
    fi
    exec claudex-lite "$@"
    ;;
  full)
    shift
    if ! command -v claudex >/dev/null 2>&1; then
      echo "cx: 'claudex' (full tier) not on PATH." >&2
      exit 1
    fi
    exec claudex "$@"
    ;;
  *)
    if command -v claudex >/dev/null 2>&1; then
      exec claudex "$@"
    elif command -v claudex-lite >/dev/null 2>&1; then
      exec claudex-lite "$@"
    else
      echo "cx: neither 'claudex' nor 'claudex-lite' is on PATH." >&2
      exit 1
    fi
    ;;
esac
